---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const sidebar = [
  {
    section: 'Getting Started',
    items: [
      { title: 'Introduction', href: '/docs/getting-started' },
      { title: 'Installation', href: '/docs/installation' },
    ],
  },
  {
    section: 'Usage',
    items: [
      { title: 'Generating Cards', href: '/docs/generating-cards' },
      { title: 'Reviewing Cards', href: '/docs/reviewing-cards' },
      { title: 'Importing & Exporting', href: '/docs/importing-exporting' },
    ],
  },
  {
    section: 'Configuration',
    items: [
      { title: 'API Keys', href: '/docs/api-keys' },
      { title: 'Grading Modes', href: '/docs/grading-modes' },
      { title: 'Notifications', href: '/docs/notifications' },
    ],
  },
];
---

<Base title={`${title} — Amber Docs`}>
  <Nav active="docs" />

  <div class="pt-16 min-h-screen flex">
    <!-- Sidebar -->
    <aside class="hidden md:block w-64 shrink-0 border-r border-border/50 px-6 py-10 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto">
      <nav class="space-y-8">
        {sidebar.map(group => (
          <div>
            <h4 class="font-mono text-[10px] uppercase tracking-widest text-neutral-600 mb-3">{group.section}</h4>
            <ul class="space-y-1">
              {group.items.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'block px-3 py-1.5 rounded-md text-sm transition-colors',
                      currentPath === item.href || currentPath === item.href + '/'
                        ? 'text-accent bg-accent/5 border-l-2 border-accent'
                        : 'text-neutral-400 hover:text-neutral-200 hover:bg-surface/50',
                    ]}
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Content -->
    <main class="flex-1 min-w-0 px-6 md:px-12 py-10 max-w-3xl">
      <!-- Mobile nav -->
      <div class="md:hidden mb-8">
        <details class="group">
          <summary class="flex items-center gap-2 cursor-pointer text-sm text-neutral-400 font-mono">
            <svg class="w-4 h-4 group-open:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            Navigation
          </summary>
          <nav class="mt-4 space-y-4 pl-2 border-l border-border">
            {sidebar.map(group => (
              <div>
                <h4 class="font-mono text-[10px] uppercase tracking-widest text-neutral-600 mb-2">{group.section}</h4>
                <ul class="space-y-1">
                  {group.items.map(item => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          'block px-3 py-1 text-sm transition-colors',
                          currentPath === item.href || currentPath === item.href + '/'
                            ? 'text-accent'
                            : 'text-neutral-400 hover:text-neutral-200',
                        ]}
                      >
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </nav>
        </details>
      </div>

      <article class="prose-docs">
        <slot />
      </article>
    </main>
  </div>
</Base>
