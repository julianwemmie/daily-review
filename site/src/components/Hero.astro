---
---

<section class="relative min-h-screen flex items-center justify-center grid-bg overflow-hidden">
  <!-- Radial glow behind terminal -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-terracotta/5 rounded-full blur-[120px] animate-glow-pulse pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 pt-32 pb-24 text-center">
    <!-- Badge -->
    <div class="animate-fade-up inline-flex items-center gap-2 px-3 py-1 rounded-full border border-earth-border bg-cream-light/50 mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-terracotta animate-pulse"></span>
      <span class="text-xs font-mono text-earth-medium">Open source spaced repetition for developers</span>
    </div>

    <!-- Headline -->
    <h1 class="animate-fade-up-delay-1 font-extrabold text-5xl md:text-7xl tracking-tight leading-[1.05] mb-6 text-earth">
      Turn conversations into<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-terracotta to-gold">lasting knowledge</span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-fade-up-delay-2 text-lg md:text-xl text-earth-medium max-w-2xl mx-auto mb-10 leading-relaxed">
      Install the Claude Code plugin and Amber automatically generates flashcards from your sessions. An AI grader evaluates your recall with FSRS scheduling so you actually retain what you learn.
    </p>

    <!-- Terminal window -->
    <div class="animate-fade-up-delay-3 terminal max-w-xl mx-auto mb-10">
      <div class="terminal-header">
        <div class="terminal-dot bg-[#ff5f57]"></div>
        <div class="terminal-dot bg-[#febc2e]"></div>
        <div class="terminal-dot bg-[#28c840]"></div>
        <span class="ml-3 text-xs font-mono text-earth-muted">~</span>
      </div>
      <div class="p-5 text-left">
        <div class="font-mono text-sm">
          <span class="text-earth-muted">$</span>
          <span id="typed-command" class="text-terracotta-light ml-2"></span>
          <span id="cursor" class="text-terracotta-light animate-blink">_</span>
        </div>
        <div id="output-lines" class="mt-3 space-y-1 font-mono text-xs text-terminal-text/60 hidden">
          <div><span class="text-terminal-text/40">></span> Marketplace added <span class="text-terracotta-light">&#10003;</span></div>
          <div><span class="text-terminal-text/40">></span> Installing amber-flashcards plugin...</div>
          <div><span class="text-terminal-text/40">></span> Plugin installed <span class="text-terracotta-light">&#10003;</span></div>
          <div><span class="text-terminal-text/40">></span> Flashcards will be <span class="text-terracotta-light">auto-generated</span> from your sessions</div>
        </div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="animate-fade-up-delay-4 flex items-center justify-center gap-4">
      <a
        href="/docs/getting-started"
        class="group relative inline-flex items-center gap-2 px-6 py-3 bg-terracotta text-white font-semibold text-sm rounded-lg hover:bg-terracotta-dim transition-colors"
      >
        Get Started
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="https://github.com/julianwemmie/amber-cards"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 border border-earth-border text-earth font-medium text-sm rounded-lg hover:border-earth-medium hover:text-earth transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-earth-muted">
    <span class="text-xs font-mono">scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-earth-muted to-transparent"></div>
  </div>
</section>

<script>
  const command = 'claude plugin install amber-flashcards@amber';
  const typedEl = document.getElementById('typed-command');
  const cursorEl = document.getElementById('cursor');
  const outputEl = document.getElementById('output-lines');

  let i = 0;
  function typeChar() {
    if (!typedEl) return;
    if (i < command.length) {
      typedEl.textContent += command[i];
      i++;
      setTimeout(typeChar, 60 + Math.random() * 40);
    } else {
      // Show output after typing
      setTimeout(() => {
        if (outputEl) {
          outputEl.classList.remove('hidden');
          const lines = outputEl.children;
          Array.from(lines).forEach((line, idx) => {
            (line as HTMLElement).style.opacity = '0';
            (line as HTMLElement).style.transform = 'translateY(4px)';
            (line as HTMLElement).style.transition = 'opacity 0.3s ease, transform 0.3s ease';
            setTimeout(() => {
              (line as HTMLElement).style.opacity = '1';
              (line as HTMLElement).style.transform = 'translateY(0)';
            }, idx * 400);
          });
        }
        if (cursorEl) cursorEl.style.display = 'none';
      }, 500);
    }
  }

  // Start typing after a brief delay, skip animation if reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    if (typedEl) typedEl.textContent = command;
    if (cursorEl) cursorEl.style.display = 'none';
    if (outputEl) {
      outputEl.classList.remove('hidden');
      Array.from(outputEl.children).forEach(line => {
        (line as HTMLElement).style.opacity = '1';
      });
    }
  } else {
    setTimeout(typeChar, 800);
  }
</script>
