---
interface Props {
  active?: 'home' | 'docs';
}
const { active = 'home' } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-earth-border/50 backdrop-blur-xl bg-cream/80">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/amber_logo.png" alt="Amber logo" class="w-8 h-8" />
      <span class="font-bold text-sm tracking-tight text-terracotta">Amber</span>
    </a>

    <div class="flex items-center gap-1">
      <a
        href="/"
        class:list={[
          'px-3 py-1.5 rounded-md text-sm transition-colors',
          active === 'home' ? 'text-terracotta bg-terracotta/5' : 'text-earth-medium hover:text-earth',
        ]}
      >
        Home
      </a>
      <a
        href="/docs/getting-started"
        class:list={[
          'px-3 py-1.5 rounded-md text-sm transition-colors',
          active === 'docs' ? 'text-terracotta bg-terracotta/5' : 'text-earth-medium hover:text-earth',
        ]}
      >
        Docs
      </a>
      <div class="w-px h-4 bg-earth-border mx-2"></div>
      <a
        href="https://app.amber.cards"
        class="px-3 py-1.5 bg-terracotta text-white text-sm font-medium rounded-md hover:bg-terracotta-dim transition-colors"
      >
        Open App
      </a>
    </div>
  </div>
</nav>
