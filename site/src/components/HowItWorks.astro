---
---

<section class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <span class="inline-block font-mono text-xs text-terracotta mb-4 tracking-widest uppercase">How it works</span>
      <h2 class="font-bold text-3xl md:text-4xl tracking-tight text-earth">
        Steps to <span class="text-transparent bg-clip-text bg-gradient-to-r from-terracotta to-gold">never forget</span>
      </h2>
    </div>

    <!-- Flow layout (desktop) -->
    <div class="hidden md:block max-w-5xl mx-auto">
      <div class="grid grid-cols-3 gap-6">
        <!-- Column 1: Two entry points stacked -->
        <div class="flex flex-col">
          <!-- Add Cards -->
          <div class="group">
            <div class="p-5 rounded-xl border border-earth-border bg-cream-light/50 hover:bg-cream-light transition-all duration-300">
              <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded-lg bg-terracotta/10 border border-terracotta/20 flex items-center justify-center text-terracotta group-hover:bg-terracotta/20 transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                </div>
                <span class="font-mono text-xs text-earth-muted">01a</span>
              </div>
              <h3 class="font-bold text-lg mb-1 text-earth">Add Cards</h3>
              <p class="text-sm text-earth-medium leading-relaxed">Create manually or import from Anki and Mochi.</p>
            </div>
          </div>

          <!-- "or" divider -->
          <div class="flex items-center justify-center py-2">
            <span class="text-xs font-mono text-earth-muted">or</span>
          </div>

          <!-- Claude Code Plugin -->
          <div class="group">
            <div class="p-5 rounded-xl border border-earth-border bg-cream-light/50 hover:bg-cream-light transition-all duration-300">
              <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded-lg bg-terracotta/10 border border-terracotta/20 flex items-center justify-center text-terracotta group-hover:bg-terracotta/20 transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>
                </div>
                <span class="font-mono text-xs text-earth-muted">01b</span>
              </div>
              <h3 class="font-bold text-lg mb-1 text-earth">Claude Code Plugin</h3>
              <p class="text-sm text-earth-medium leading-relaxed">Auto-generate cards from your coding sessions.</p>
            </div>
          </div>
        </div>

        <!-- Column 2: Review (vertically centered) -->
        <div class="flex items-center">
          <div class="group relative w-full">
            <!-- Connector line to next -->
            <div class="hidden md:block absolute top-1/2 -translate-y-px left-[calc(100%+0.25rem)] w-[calc(100%-2.5rem)] h-px">
              <div class="h-full bg-gradient-to-r from-terracotta/30 to-terracotta/5"></div>
            </div>
            <!-- Connector line from prev -->
            <div class="hidden md:block absolute top-1/2 -translate-y-px right-[calc(100%+0.25rem)] w-[calc(100%-2.5rem)] h-px">
              <div class="h-full bg-gradient-to-r from-terracotta/5 to-terracotta/30"></div>
            </div>
            <div class="p-6 rounded-xl border border-earth-border bg-cream-light/50 hover:bg-cream-light transition-all duration-300">
              <div class="flex items-center justify-between mb-5">
                <div class="w-10 h-10 rounded-lg bg-terracotta/10 border border-terracotta/20 flex items-center justify-center text-terracotta group-hover:bg-terracotta/20 transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
                </div>
                <span class="font-mono text-xs text-earth-muted">02</span>
              </div>
              <h3 class="font-bold text-lg mb-2 text-earth">Review</h3>
              <p class="text-sm text-earth-medium leading-relaxed">Answer in your own words. The AI grader evaluates your response and gives you a score with feedback.</p>
            </div>
          </div>
        </div>

        <!-- Column 3: Retain (vertically centered) -->
        <div class="flex items-center">
          <div class="group w-full">
            <div class="p-6 rounded-xl border border-earth-border bg-cream-light/50 hover:bg-cream-light transition-all duration-300">
              <div class="flex items-center justify-between mb-5">
                <div class="w-10 h-10 rounded-lg bg-terracotta/10 border border-terracotta/20 flex items-center justify-center text-terracotta group-hover:bg-terracotta/20 transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <span class="font-mono text-xs text-earth-muted">03</span>
              </div>
              <h3 class="font-bold text-lg mb-2 text-earth">Retain</h3>
              <p class="text-sm text-earth-medium leading-relaxed">FSRS schedules cards at scientifically optimal intervals. Review a little each day and actually remember what you learn.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile: simple stacked layout -->
    <div class="md:hidden space-y-4">
      {[
        { num: '01a', title: 'Add Cards', desc: 'Create cards manually or import from Anki and Mochi.', icon: 'M12 4.5v15m7.5-7.5h-15' },
        { num: '01b', title: 'Claude Code Plugin', desc: 'Auto-generate cards from your coding sessions in the background.', icon: 'M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5' },
        { num: '02', title: 'Review', desc: 'Answer in your own words. The AI grader evaluates your response and gives you a score with feedback.', icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z' },
        { num: '03', title: 'Retain', desc: 'FSRS schedules cards at scientifically optimal intervals. Review a little each day and actually remember what you learn.', icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z' },
      ].map((step) => (
        <div class="p-6 rounded-xl border border-earth-border bg-cream-light/50">
          <div class="flex items-center justify-between mb-5">
            <div class="w-10 h-10 rounded-lg bg-terracotta/10 border border-terracotta/20 flex items-center justify-center text-terracotta">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={step.icon} /></svg>
            </div>
            <span class="font-mono text-xs text-earth-muted">{step.num}</span>
          </div>
          <h3 class="font-bold text-lg mb-2 text-earth">{step.title}</h3>
          <p class="text-sm text-earth-medium leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
