---
const steps = [
  {
    number: '01',
    title: 'Generate',
    description: 'The /flashcards skill scans your Claude Code conversations and extracts key concepts into flashcards.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
  },
  {
    number: '02',
    title: 'Upload',
    description: 'Cards are sent to the cloud via the CLI. Authenticate once with an API key and you\'re set.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>`,
  },
  {
    number: '03',
    title: 'Review',
    description: 'Answer cards in free-form text. An LLM grader scores your response and gives feedback.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342" /></svg>`,
  },
  {
    number: '04',
    title: 'Schedule',
    description: 'FSRS determines when each card comes back based on how well you knew it. Optimized intervals, real retention.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
];
---

<section class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <span class="inline-block font-mono text-xs text-terracotta mb-4 tracking-widest uppercase">How it works</span>
      <h2 class="font-bold text-3xl md:text-4xl tracking-tight text-earth">
        Four steps to <span class="text-transparent bg-clip-text bg-gradient-to-r from-terracotta to-olive">never forget</span>
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-4 gap-6">
      {steps.map((step, idx) => (
        <div class="group relative">
          {/* Connector line (not on last) */}
          {idx < 3 && (
            <div class="hidden md:block absolute top-10 left-[calc(100%+0.25rem)] w-[calc(100%-2.5rem)] h-px">
              <div class="h-full bg-gradient-to-r from-terracotta/30 to-terracotta/5"></div>
            </div>
          )}

          <div class="p-6 rounded-xl border border-earth-border bg-cream-light/50 hover:bg-cream-light transition-all duration-300">
            {/* Step number + icon */}
            <div class="flex items-center justify-between mb-5">
              <div class="w-10 h-10 rounded-lg bg-terracotta/10 border border-terracotta/20 flex items-center justify-center text-terracotta group-hover:bg-terracotta/20 transition-colors">
                <Fragment set:html={step.icon} />
              </div>
              <span class="font-mono text-xs text-earth-muted">{step.number}</span>
            </div>

            {/* Content */}
            <h3 class="font-bold text-lg mb-2 text-earth">{step.title}</h3>
            <p class="text-sm text-earth-medium leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
