---
---

<section class="relative py-32 px-6 border-t border-earth-border/50">
  <div class="max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block font-mono text-xs text-terracotta mb-4 tracking-widest uppercase">Integrations</span>
      <h2 class="font-bold text-3xl md:text-4xl tracking-tight mb-4 text-earth">
        Supercharge with the <span class="text-transparent bg-clip-text bg-gradient-to-r from-terracotta to-gold">CLI & plugin</span>
      </h2>
      <p class="text-earth-medium max-w-xl mx-auto">Amber works great on its own. But if you use Claude Code, the CLI and plugin can generate flashcards from your sessions automatically.</p>
    </div>

    <!-- Install steps -->
    <div class="space-y-4 max-w-2xl mx-auto">
      <!-- Step 1 -->
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot bg-[#ff5f57]"></div>
          <div class="terminal-dot bg-[#febc2e]"></div>
          <div class="terminal-dot bg-[#28c840]"></div>
          <span class="ml-3 text-xs font-mono text-earth-muted">Install CLI & Authenticate</span>
        </div>
        <div class="p-4 flex flex-col gap-2 group">
          <div class="flex items-center justify-between">
            <code class="font-mono text-sm">
              <span class="text-terminal-text/50">$</span>
              <span class="text-terminal-text ml-2">npm install -g amber-cards && amber login</span>
            </code>
            <button
              class="copy-btn opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity text-terminal-text/50 hover:text-terracotta-light p-1"
              data-copy="npm install -g amber-cards && amber login"
              aria-label="Copy to clipboard"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot bg-[#ff5f57]"></div>
          <div class="terminal-dot bg-[#febc2e]"></div>
          <div class="terminal-dot bg-[#28c840]"></div>
          <span class="ml-3 text-xs font-mono text-earth-muted">Add Marketplace & Install Plugin</span>
        </div>
        <div class="p-4 flex flex-col gap-2 group">
          <div class="flex items-center justify-between">
            <code class="font-mono text-sm">
              <span class="text-terminal-text/50">$</span>
              <span class="text-terminal-text ml-2">claude plugin marketplace add julianwemmie/amber-claude-plugin</span>
            </code>
            <button
              class="copy-btn opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity text-terminal-text/50 hover:text-terracotta-light p-1"
              data-copy="claude plugin marketplace add julianwemmie/amber-claude-plugin"
              aria-label="Copy to clipboard"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
              </svg>
            </button>
          </div>
          <div class="flex items-center justify-between mt-1">
            <code class="font-mono text-sm">
              <span class="text-terminal-text/50">$</span>
              <span class="text-terminal-text ml-2">claude plugin install amber-flashcards@amber</span>
            </code>
            <button
              class="copy-btn opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity text-terminal-text/50 hover:text-terracotta-light p-1"
              data-copy="claude plugin install amber-flashcards@amber"
              aria-label="Copy to clipboard"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div id="copy-status" class="sr-only" aria-live="polite"></div>

    <!-- CTA below -->
    <div class="text-center mt-12">
      <p class="text-sm text-earth-medium">Optional — the plugin runs automatically after each Claude Code session, generating cards in the background.</p>
    </div>
  </div>
</section>

<script>
  const copyStatus = document.getElementById('copy-status');
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy;
      if (text) {
        navigator.clipboard.writeText(text);
        if (copyStatus) copyStatus.textContent = 'Copied!';
        const svg = btn.querySelector('svg');
        if (svg) {
          const original = svg.innerHTML;
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.5 12.75l6 6 9-13.5" />';
          (btn as HTMLElement).classList.add('!opacity-100');
          setTimeout(() => {
            svg.innerHTML = original;
            (btn as HTMLElement).classList.remove('!opacity-100');
            if (copyStatus) copyStatus.textContent = '';
          }, 2000);
        }
      }
    });
  });
</script>
