---
const features = [
  {
    title: 'LLM Grading',
    description: 'No rigid answer matching. An AI evaluates your free-form response against the source material and provides a score with feedback.',
    tag: 'AI',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`,
  },
  {
    title: 'FSRS Scheduling',
    description: 'State-of-the-art spaced repetition algorithm. Cards surface at mathematically optimal intervals to maximize long-term retention.',
    tag: 'Core',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
  },
  {
    title: 'Import & Export',
    description: 'Bring cards from Anki (.apkg) or Mochi (.mochi) decks. Export your collection any time. No lock-in.',
    tag: 'Data',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
  },
  {
    title: 'Email Nudges',
    description: 'Escalating reminders when you skip reviews. Starts gentle (1 day), builds urgency (3, 7, 14 days), then stops. One-click unsubscribe.',
    tag: 'Retention',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>`,
  },
  {
    title: 'Speech-to-Text',
    description: 'Answer cards by speaking. Hands-free review for when you\'re away from the keyboard.',
    tag: 'Input',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" /></svg>`,
  },
  {
    title: 'Retention Analysis',
    description: 'AI analyzes your review history over time to surface patterns — what you consistently struggle with, where you\'re improving, and what needs more attention.',
    tag: 'AI',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>`,
  },
];
---

<section class="relative py-32 px-6 border-t border-earth-border/50">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <span class="inline-block font-mono text-xs text-terracotta mb-4 tracking-widest uppercase">Features</span>
      <h2 class="font-bold text-3xl md:text-4xl tracking-tight text-earth">
        Built for developers who<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-terracotta to-gold">learn by doing</span>
      </h2>
    </div>

    <!-- Feature grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((feature) => (
        <div class="feature-card p-6 rounded-xl border border-earth-border bg-cream-light/50">
          <div class="flex items-start justify-between mb-4">
            <div class="w-9 h-9 rounded-lg bg-terracotta/10 border border-terracotta/20 flex items-center justify-center text-terracotta">
              <Fragment set:html={feature.icon} />
            </div>
            <span class="font-mono text-[10px] text-earth-muted uppercase tracking-wider px-2 py-0.5 rounded border border-earth-border">{feature.tag}</span>
          </div>
          <h3 class="font-bold text-base mb-2 text-earth">{feature.title}</h3>
          <p class="text-sm text-earth-medium leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
