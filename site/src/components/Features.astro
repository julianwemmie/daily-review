---

<section class="relative py-32 px-6 border-t border-border/50">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <span class="inline-block font-mono text-xs text-accent mb-4 tracking-widest uppercase">Features</span>
      <h2 class="font-display font-bold text-3xl md:text-4xl tracking-tight">
        Built for developers who<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-cyan">learn by doing</span>
      </h2>
    </div>

    <!-- Feature grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((feature) => (
        <div class="feature-card p-6 rounded-xl border border-border bg-surface/30">
          <div class="flex items-start justify-between mb-4">
            <div class="w-9 h-9 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent">
              <Fragment set:html={feature.icon} />
            </div>
            <span class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider px-2 py-0.5 rounded border border-border">{feature.tag}</span>
          </div>
          <h3 class="font-display font-bold text-base mb-2 text-neutral-100">{feature.title}</h3>
          <p class="text-sm text-neutral-500 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
